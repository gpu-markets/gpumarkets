---
/**
 * Venues — placeholder for the per-venue directory. Phase 2 will generate
 * a detail page per venue from a content collection, with cadence,
 * terms-of-service review date, and observed-rate timeline.
 */
import Base from '../layouts/Base.astro';
import Eyebrow from '../components/Eyebrow.astro';
---

<Base title="Venues · GPU Markets" currentPage="venues">
  <section class="hero">
    <div class="wrap">
      <h1>Venues</h1>
      <p class="deck">
        The 12 rental venues currently observed by GPU Markets, the access
        method used to collect rates, and the eligibility status of each
        venue for the daily estimator.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <Eyebrow label="Coming In Phase 2" />
      <div class="prose">
        <p>
          A per‑venue directory page will replace this stub. Each
          venue gets its own page with: scrape cadence, last
          terms‑of‑service review date, the GPU SKUs observed,
          historical eligibility transitions, and the
          per‑venue‑per‑series observed rate timeline.
        </p>
        <p>
          The current 12‑venue list and eligibility status is
          available on the landing page under
          <a href="/#venue-coverage">\u00A7 05 · Venue Coverage</a>.
        </p>
      </div>
    </div>
  </section>
</Base>
