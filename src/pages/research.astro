---
/**
 * Research index. Lists all notes in reverse chronological order; the
 * lead note links to its detail page, previous notes link back to the
 * landing page's § 06 · Research section until per-note detail pages
 * are filled out in subsequent passes.
 */
import Base from '../layouts/Base.astro';
import Eyebrow from '../components/Eyebrow.astro';
import { allNotes, detailPageSlugs } from '../lib/research-notes';
---

<Base title="Research · GPU Markets" currentPage="research">
  <section class="hero">
    <div class="wrap">
      <h1>Research</h1>
      <p class="deck">
        Notes on what the data is doing — spread analysis, forward
        curves, residual‑value implications, and historical
        backtests on GPU rental rates.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <Eyebrow label="Notes" />
      <div class="research">
        <ol>
          {
            allNotes.map((n) => (
              <li>
                <span class="d">{n.date}</span>
                <span class="t">
                  {detailPageSlugs.has(n.slug) ? (
                    <a href={`/research/${n.slug}/`}>{n.title}</a>
                  ) : (
                    n.title
                  )}
                </span>
              </li>
            ))
          }
        </ol>
      </div>
      <p class="footnote">
        Each note will get a dedicated detail page as the archive fills
        out. The current lead note is available now; previous titles
        are listed for reference and will become linkable in subsequent
        passes. A short summary of the most recent notes also appears
        on the landing page under
        <a href="/#research">§ 06 · Research</a>.
      </p>
    </div>
  </section>
</Base>
