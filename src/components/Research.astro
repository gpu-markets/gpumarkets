---
import Eyebrow from './Eyebrow.astro';
import { leadNote as lead, previousNotes as previous } from '../lib/research-notes';

/**
 * § 06 · Research — the lead note (prominent .lead-note block) and an
 * ordered list of previous notes (.research ol). Phase 1 links all
 * entries to /research; Phase 2 will generate per-slug MDX pages.
 *
 * Data lives in src/lib/research-notes.ts so the RSS feed
 * (src/pages/feed.xml.ts) can consume the same source.
 */
---

<section>
  <div class="wrap">
    <Eyebrow number="06" label="Research · Lead Note" aside={lead.date} />
    <div class="lead-note">
      <div class="lead-date">{lead.date}</div>
      <h2 class="lead-head"><a href="/research">{lead.title}</a></h2>
      <p class="lead-deck">{lead.deck}</p>
      <p class="lead-more"><a href="/research">Read the full note →</a></p>
    </div>

    <div class="eyebrow-row previous-eyebrow">
      <span class="num">§</span>
      <span class="dot">·</span>
      <span class="label">Previous Notes</span>
    </div>
    <div class="eyebrow-rule"></div>

    <div class="research">
      <ol>
        {
          previous.map((n) => (
            <li>
              <span class="d">{n.date}</span>
              <span class="t"><a href="/research">{n.title}</a></span>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
