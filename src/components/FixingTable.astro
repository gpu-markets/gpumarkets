---
import type { Series } from '../lib/types';
import CapacityWeightedRow from './CapacityWeightedRow.astro';

/**
 * Fixing table — renders one tier of series as a dense data table
 * with expandable spec rows and sparklines. Matches the standalone
 * HTML class names exactly so shared.css applies unchanged.
 *
 * Strike metadata: a nominal strike time is passed via `strikeAt`.
 * Rows whose `series.fixedAt` diverges get a "◦" off-strike marker.
 *
 * Footnotes: each series may carry `footnotes: string[]`; these are
 * globally numbered across the tier in row-order, rendered as
 * superscripts next to the ticker, and listed below the table.
 */

export interface Props {
  series: Series[];
  ariaLabel: string;
  /** ISO datetime, e.g. "2026-04-18T00:30:00Z". */
  strikeAt: string;
}

const { series, ariaLabel, strikeAt } = Astro.props;

function pctClass(v: number): 'pos' | 'neg' | 'zero' {
  if (v > 0) return 'pos';
  if (v < 0) return 'neg';
  return 'zero';
}
function pctSign(v: number): string {
  if (v > 0) return '+';
  if (v < 0) return '\u2212';
  return '\u00A0';
}
function pctValue(v: number): string {
  return Math.abs(v).toFixed(2) + '%';
}
function slugify(ticker: string): string {
  // GPUM.H100.SXM.SPOT -> h100-sxm-spot
  return ticker.replace(/^GPUM\./, '').toLowerCase().replace(/\./g, '-');
}

function sparkContext(path: string): { firstY: number; lastX: number; lastY: number } {
  const matches = [...path.matchAll(/([ML])([\d.]+),([\d.]+)/g)];
  const first = matches[0];
  const last = matches[matches.length - 1];
  return {
    firstY: first ? Number(first[3]) : 9,
    lastX: last ? Number(last[2]) : 80,
    lastY: last ? Number(last[3]) : 9,
  };
}

/**
 * "2026-04-18T00:30:00Z" -> "2026‑04‑18 · 00:30 UTC", with non-breaking
 * hyphens in the date to match the site-wide typographic convention.
 */
function strikeLabel(iso: string): string {
  const date = iso.slice(0, 10).replace(/-/g, '\u2011');
  const time = iso.slice(11, 16);
  return `${date} \u00B7 ${time} UTC`;
}

// Flatten footnotes into a single numbered list per tier, in row order.
type NumberedFootnote = { n: number; text: string; seriesId: string };
const footnoteList: NumberedFootnote[] = [];
const footnoteIndexBySeries = new Map<string, number[]>();
for (const s of series) {
  if (!s.footnotes || s.footnotes.length === 0) continue;
  const indices: number[] = [];
  for (const text of s.footnotes) {
    const n = footnoteList.length + 1;
    footnoteList.push({ n, text, seriesId: s.id });
    indices.push(n);
  }
  footnoteIndexBySeries.set(s.id, indices);
}

const offStrike = series.filter((s) => s.fixedAt && s.fixedAt !== strikeAt);
---

<p class="strike-line">
  <span class="mono">Struck {strikeLabel(strikeAt)}</span>
  <span class="strike-sep"> · </span>
  <span class="strike-count">{series.length} series</span>
  {offStrike.length > 0 && (
    <span class="strike-note">
      <span class="strike-sep"> · </span>
      <span>{offStrike.length} off-strike (◦ marker)</span>
    </span>
  )}
</p>

<div class="table-scroll">
  <table class="fixing" aria-label={ariaLabel}>
    <thead>
      <tr>
        <th scope="col">Series</th>
        <th scope="col" class="num">Today</th>
        <th scope="col" class="num">Δ 1d</th>
        <th scope="col" class="num">Δ 7d</th>
        <th scope="col" class="num">Δ 30d</th>
        <th scope="col" class="num">Obs</th>
        <th scope="col" class="num">Venues</th>
        <th scope="col" class="num">30d</th>
      </tr>
    </thead>
    <tbody>
      {
        series.map((s) => {
          const slug = slugify(s.id);
          const specId = `spec-${slug}`;
          const noteIndices = footnoteIndexBySeries.get(s.id);
          const isOffStrike = Boolean(s.fixedAt && s.fixedAt !== strikeAt);
          const spark = sparkContext(s.sparkPath);
          return (
            <>
              <tr class="chip-row" data-series={s.id} tabindex="0">
                <td class="series">
                  <button
                    class="row-toggle"
                    aria-expanded="false"
                    aria-controls={specId}
                    type="button"
                  >
                    <span class="chev">›</span>
                    <span class="name">
                      {s.chipName} · <span class="vram">{s.vram}</span> · {s.tenor}
                    </span>
                    <span class="tick">
                      {s.id}
                      {isOffStrike && (
                        <span
                          class="off-strike"
                          aria-label="Off-strike fixing — see notes"
                          title={`Struck at ${s.fixedAt?.slice(11, 16)} UTC, not ${strikeAt.slice(11, 16)} UTC`}
                        >
                          {' ◦'}
                        </span>
                      )}
                      {noteIndices && noteIndices.map((n) => (
                        <sup class="fn-ref">
                          <a href={`#fn-${slug}-${n}`} id={`fnref-${slug}-${n}`}>{n}</a>
                        </sup>
                      ))}
                    </span>
                  </button>
                </td>
                <td class="num">${s.price.toFixed(4)}</td>
                <td class={`num pct ${pctClass(s.delta1d)}`}>
                  <span class="sign">{pctSign(s.delta1d)}</span>{pctValue(s.delta1d)}
                </td>
                <td class={`num pct ${pctClass(s.delta7d)}`}>
                  <span class="sign">{pctSign(s.delta7d)}</span>{pctValue(s.delta7d)}
                </td>
                <td class={`num pct ${pctClass(s.delta30d)}`}>
                  <span class="sign">{pctSign(s.delta30d)}</span>{pctValue(s.delta30d)}
                </td>
                <td class="num">{s.obs.toLocaleString('en-US')}</td>
                <td class="num">{s.venueCount}</td>
                <td class="num">
                  <svg
                    class="spark"
                    width="80"
                    height="18"
                    viewBox="0 0 80 18"
                    aria-hidden="true"
                  >
                    <line class="spark-baseline" x1="0" x2="80" y1={spark.firstY} y2={spark.firstY} />
                    <path d={s.sparkPath} />
                    <circle class="spark-end" cx={spark.lastX} cy={spark.lastY} r="1.8" />
                  </svg>
                </td>
              </tr>
              <CapacityWeightedRow series={s} />
              <tr class="spec-row" id={specId} hidden>
                <td colspan="8">
                  <dl class="specs">
                    {s.specs.map(([k, v]) => (
                      <div>
                        <dt>{k}</dt>
                        <dd>{v}</dd>
                      </div>
                    ))}
                  </dl>
                </td>
              </tr>
            </>
          );
        })
      }
    </tbody>
  </table>
</div>

{footnoteList.length > 0 && (
  <section class="fixing-notes" aria-label="Notes on this fixing">
    <div class="fixing-notes-label">Notes on this fixing</div>
    <ol class="fixing-notes-list">
      {footnoteList.map((fn) => {
        const slug = slugify(fn.seriesId);
        return (
          <li id={`fn-${slug}-${fn.n}`}>
            <span class="fn-ticker mono">{fn.seriesId}</span>
            <span class="fn-sep"> · </span>
            <span class="fn-body">{fn.text}</span>
            <a class="fn-back" href={`#fnref-${slug}-${fn.n}`} aria-label={`Return to ${fn.seriesId}`}>↩</a>
          </li>
        );
      })}
    </ol>
  </section>
)}

<style>
  .strike-line {
    font-family: var(--ui);
    font-size: 12px;
    color: #555042;
    letter-spacing: 0.02em;
    margin: 0 0 10px;
  }
  .strike-line .mono { font-family: var(--mono); font-size: 12.5px; color: var(--ink); }
  .strike-line .strike-sep { color: #7b7464; }

  .off-strike {
    color: #5d5748;
    font-family: var(--mono);
  }

  sup.fn-ref {
    font-family: var(--mono);
    font-size: 10px;
    margin-left: 2px;
    vertical-align: super;
    line-height: 0;
  }
  sup.fn-ref a {
    color: #5c5647;
    text-decoration: none;
    border-bottom: 1px dotted #827866;
  }
  sup.fn-ref a:hover { color: var(--ink); border-bottom-color: var(--ink); }

  .fixing-notes {
    margin: 14px 0 0;
    padding-top: 10px;
    border-top: 1px solid var(--rule);
  }
  .fixing-notes-label {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #5d584a;
    margin-bottom: 6px;
  }
  .fixing-notes-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: fn;
  }
  .fixing-notes-list li {
    position: relative;
    padding: 4px 0 4px 28px;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink);
    counter-increment: fn;
  }
  .fixing-notes-list li::before {
    content: counter(fn);
    position: absolute;
    left: 0;
    top: 4px;
    width: 22px;
    text-align: right;
    font-family: var(--mono);
    font-size: 11.5px;
    color: #6a6454;
  }
  .fn-ticker { font-size: 12px; color: #5d5748; }
  .fn-sep { color: #6b6556; }
  .fn-back {
    margin-left: 6px;
    font-family: var(--mono);
    color: #605949;
    text-decoration: none;
  }
  .fn-back:hover { color: var(--ink); }
</style>
