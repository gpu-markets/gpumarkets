---
import Eyebrow from './Eyebrow.astro';
import { glossaryOrder, glossaryTerms } from '../lib/glossary-terms';
---

<Eyebrow label="Glossary" />
<table class="glossary" aria-label="Ticker glossary">
  <tbody>
    {
      glossaryOrder.map((id) => (
        <tr>
          <td class="term">{glossaryTerms[id].label}</td>
          <td class="def">{glossaryTerms[id].description}</td>
        </tr>
      ))
    }
  </tbody>
</table>
