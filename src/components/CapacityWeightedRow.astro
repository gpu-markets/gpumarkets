---
import type { Series } from '../lib/types';
import GlossaryTerm from './GlossaryTerm.astro';

/**
 * Capacity-weighted companion row (.cw research series). Rendered
 * inline by FixingTable beneath a chip-row when the series has a
 * `priceCW` (or a `suppressedCW` reason). The row shows the weighted-
 * median fix, its delta vs the headline fix, and the tier distribution
 * of surviving observations. Suppressed state is rendered as a single
 * muted line so the table cadence stays even.
 *
 * No new CSS: reuses `mono`, `pct`, `pos`/`neg`/`zero`, `sign`, `mute`
 * from shared.css. Span structure mirrors spec-row (single colspan=8 td).
 */

export interface Props {
  series: Series;
}

const { series } = Astro.props;

const hasCW =
  typeof series.priceCW === 'number' &&
  typeof series.deltaCWvsFix === 'number';
const suppressed = series.suppressedCW;
const show = hasCW || !!suppressed;
type TierTermId = 't1' | 't2' | 't3';
type TierBreakdownItem = { count: string; tier: string; termId: TierTermId };
const tierItems: TierBreakdownItem[] = (series.venueTierBreakdown ?? '')
  .split(' · ')
  .map((part) => {
    const [count, tier] = part.split(' ');
    if (!count || !tier) return null;
    const termId = tier.toLowerCase();
    if (termId !== 't1' && termId !== 't2' && termId !== 't3') return null;
    return { count, tier, termId };
  })
  .filter((item): item is TierBreakdownItem => item !== null);

function pctClass(v: number): 'pos' | 'neg' | 'zero' {
  if (v > 0) return 'pos';
  if (v < 0) return 'neg';
  return 'zero';
}
function pctSign(v: number): string {
  if (v > 0) return '+';
  if (v < 0) return '−';
  return '\u00A0';
}
---

{show && (
  <tr class="cw-row" data-series={series.id} aria-label={`${series.id} capacity-weighted companion`}>
    <td colspan="8">
      <div class="cw-body">
        <span class="cw-main">
          <GlossaryTerm termId="cw" instanceId={`${series.id}-cw`} label="cw" />
          <span class="cw-sep">·</span>
          {hasCW ? (
            <>
              <span class="mono cw-price">${series.priceCW!.toFixed(4)}</span>
              <span class="cw-sep">·</span>
              <span class={`pct ${pctClass(series.deltaCWvsFix!)} cw-delta`}>
                <span class="sign">{pctSign(series.deltaCWvsFix!)}</span>
                {Math.abs(series.deltaCWvsFix!).toFixed(2)}%
              </span>
              <span class="cw-context">vs fix</span>
            </>
          ) : (
            <span class="cw-context">suppressed · {suppressed}</span>
          )}
        </span>

        {hasCW && tierItems.length > 0 && (
          <span class="cw-breakdown">
            {tierItems.map((item, index) => (
              <>
                {index > 0 && <span class="cw-break-sep">·</span>}
                <span class="cw-breakdown-item">
                  <span class="mono">{item.count}</span>{' '}
                  <GlossaryTerm
                    termId={item.termId}
                    instanceId={`${series.id}-${item.termId}`}
                    label={item.tier}
                  />
                </span>
              </>
            ))}
          </span>
        )}
      </div>
    </td>
  </tr>
)}
